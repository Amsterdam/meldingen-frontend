{
  "name": "meldingen-frontend",
  "version": "0.0.0",
  "description": "Frontends for the Signalen applications",
  "author": "Gemeente Amsterdam",
  "license": "EUPL-1.2",
  "private": true,
  "engines": {
    "node": "^24",
    "pnpm": "^10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amsterdam/meldingen-frontend.git"
  },
  "scripts": {
    "build": "pnpm run /^build:/",
    "build:admin": "pnpm -F=admin build",
    "build:bo": "pnpm -F=back-office build",
    "build:mf": "pnpm -F=melding-form build",
    "dev": "pnpm run /^dev:/",
    "dev:admin": "pnpm -F=admin dev",
    "dev:bo": "pnpm -F=back-office dev",
    "dev:mf": "pnpm -F=melding-form dev",
    "generate-api-client": "openapi-ts",
    "lint": "eslint . && stylelint --allow-empty-input '**/*.{css,scss}' && npm run prettier && pnpm -r --no-bail type-check",
    "lint-fix": "eslint . --fix && stylelint --fix '**/*.{css,scss}' && npm run prettier-fix && pnpm -r --no-bail type-check",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "prettier-fix": "prettier --write .",
    "test": "pnpm -r --no-bail --sequential test",
    "test:watch": "pnpm -r --no-bail test:watch",
    "update-minor": "npm-check-updates --target minor --upgrade && pnpm install"
  },
  "dependencies": {
    "@amsterdam/design-system-assets": "1.1.0",
    "@amsterdam/design-system-css": "2.2.0",
    "@amsterdam/design-system-react": "2.2.0",
    "@amsterdam/design-system-react-icons": "2.0.0",
    "@amsterdam/design-system-tokens": "2.2.0",
    "clsx": "2.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@eslint/json": "1.2.0",
    "@eslint/markdown": "8.0.1",
    "@hey-api/openapi-ts": "0.96.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-workspaces": "0.12.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "msw": "2.13.4",
    "npm-check-updates": "21.0.3",
    "prettier": "3.8.3",
    "stylelint": "16.26.1",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "39.0.1",
    "stylelint-order": "8.1.1",
    "stylelint-value-no-unknown-custom-properties": "6.1.1",
    "tsc-files": "1.1.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "overrides": {
      "dompurify@<3.4.0": ">=3.4.0",
      "dompurify@<=3.3.3": ">=3.4.0",
      "dompurify@>=1.0.10 <3.4.0": ">=3.4.0",
      "dompurify@>=3.0.1 <3.4.0": ">=3.4.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "uuid@<14.0.0": ">=14.0.0",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2"
    }
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
